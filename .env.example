# ═══════════════════════════════════════
# StoreIQ Environment Configuration
# ═══════════════════════════════════════
# Copy this to .env and customize

# YOLO Model (yolov8n.pt for speed, yolov8m.pt for accuracy)
YOLO_MODEL=yolov8m.pt

# Detection thresholds
CONFIDENCE_THRESHOLD=0.3
IOU_THRESHOLD=0.5

# Processing FPS (lower = faster processing, higher = smoother tracking)
PROCESS_FPS=5

# Event thresholds
DWELL_THRESHOLD_SECONDS=5.0
QUEUE_THRESHOLD_SECONDS=30.0
REENTRY_WINDOW_SECONDS=300.0
LOST_TRACK_TIMEOUT_FRAMES=30

# API
API_HOST=0.0.0.0
API_PORT=8000

# Dashboard
DASHBOARD_PORT=8501
